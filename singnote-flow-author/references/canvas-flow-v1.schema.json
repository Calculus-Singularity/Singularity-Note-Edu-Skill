{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.singnote.local/canvas-flow-v1.schema.json",
  "title": "SingNote Canvas Flow JSON v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "nodes", "edges"],
  "properties": {
    "schema": {
      "const": "singnote.flow.v1"
    },
    "nodes": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    }
  },
  "$defs": {
    "node": {
      "oneOf": [
        { "$ref": "#/$defs/startNode" },
        { "$ref": "#/$defs/markdownNode" },
        { "$ref": "#/$defs/videoNode" },
        { "$ref": "#/$defs/materialNode" },
        { "$ref": "#/$defs/exerciseNode" },
        { "$ref": "#/$defs/exerciseSetNode" },
        { "$ref": "#/$defs/programmingProblemNode" },
        { "$ref": "#/$defs/codingWorkspaceNode" },
        { "$ref": "#/$defs/splitCardNode" },
        { "$ref": "#/$defs/peerReviewNode" }
      ]
    },
    "commonNodeProperties": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "body": { "type": "string" },
        "position": { "$ref": "#/$defs/position" },
        "estimated_minutes": { "type": "integer", "minimum": 0 }
      }
    },
    "startNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title"],
      "properties": {
        "type": { "const": "start" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "position": { "$ref": "#/$defs/position" },
        "estimated_minutes": { "type": "integer", "minimum": 0 }
      }
    },
    "markdownNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "body"],
      "properties": {
        "type": { "const": "markdown" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "body": { "type": "string", "minLength": 1 },
        "position": { "$ref": "#/$defs/position" },
        "estimated_minutes": { "type": "integer", "minimum": 0 }
      }
    },
    "videoNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title"],
      "properties": {
        "type": { "const": "video" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "body": { "type": "string" },
        "position": { "$ref": "#/$defs/position" },
        "estimated_minutes": { "type": "integer", "minimum": 0 },
        "video": { "$ref": "#/$defs/video" }
      }
    },
    "materialNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "material"],
      "properties": {
        "type": { "const": "material" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "body": { "type": "string" },
        "position": { "$ref": "#/$defs/position" },
        "estimated_minutes": { "type": "integer", "minimum": 0 },
        "material": { "$ref": "#/$defs/material" }
      }
    },
    "exerciseNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "exercise"],
      "properties": {
        "type": { "const": "exercise" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "body": { "type": "string" },
        "position": { "$ref": "#/$defs/position" },
        "estimated_minutes": { "type": "integer", "minimum": 0 },
        "exercise": { "$ref": "#/$defs/exercise" }
      }
    },
    "exerciseSetNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title"],
      "properties": {
        "type": { "const": "exercise_set" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "body": { "type": "string" },
        "position": { "$ref": "#/$defs/position" },
        "estimated_minutes": { "type": "integer", "minimum": 0 }
      }
    },
    "programmingProblemNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "problem"],
      "properties": {
        "type": { "const": "programming_problem" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "body": { "type": "string" },
        "position": { "$ref": "#/$defs/position" },
        "estimated_minutes": { "type": "integer", "minimum": 0 },
        "problem": { "$ref": "#/$defs/programmingProblem" }
      }
    },
    "codingWorkspaceNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title"],
      "properties": {
        "type": { "const": "coding_workspace" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "body": { "type": "string" },
        "position": { "$ref": "#/$defs/position" },
        "estimated_minutes": { "type": "integer", "minimum": 0 },
        "workspace": { "$ref": "#/$defs/workspace" }
      }
    },
    "splitCardNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "slots"],
      "properties": {
        "type": { "const": "split_card" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "body": { "type": "string" },
        "position": { "$ref": "#/$defs/position" },
        "estimated_minutes": { "type": "integer", "minimum": 0 },
        "slots": { "$ref": "#/$defs/splitSlots" }
      }
    },
    "peerReviewNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "body"],
      "properties": {
        "type": { "const": "peer_review" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "body": { "type": "string", "minLength": 1 },
        "position": { "$ref": "#/$defs/position" },
        "estimated_minutes": { "type": "integer", "minimum": 0 }
      }
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "video": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string" },
        "asset_key": { "type": "string" },
        "duration_seconds": { "type": "integer", "minimum": 0 },
        "thumbnail_url": { "type": "string" },
        "thumbnail_asset_key": { "type": "string" }
      }
    },
    "material": {
      "type": "object",
      "additionalProperties": false,
      "anyOf": [
        { "required": ["asset_key"] },
        { "required": ["original_url"] },
        { "required": ["preview_url"] }
      ],
      "properties": {
        "asset_key": { "type": "string", "minLength": 1 },
        "file_name": { "type": "string" },
        "mime_type": { "type": "string" },
        "original_url": { "type": "string", "minLength": 1 },
        "preview_url": { "type": "string", "minLength": 1 },
        "conversion_status": {
          "enum": ["none", "pending", "processing", "ready", "failed"]
        }
      }
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "language": { "const": "python" },
        "entry_file": { "type": "string", "minLength": 1 },
        "starter_code": { "type": "string" }
      }
    },
    "splitSlots": {
      "type": "object",
      "additionalProperties": false,
      "required": ["left", "right"],
      "properties": {
        "left": { "type": "string", "minLength": 1 },
        "right": { "type": "string", "minLength": 1 }
      }
    },
    "exercise": {
      "oneOf": [
        { "$ref": "#/$defs/singleChoiceExercise" },
        { "$ref": "#/$defs/multipleChoiceExercise" },
        { "$ref": "#/$defs/trueFalseExercise" },
        { "$ref": "#/$defs/fillBlankExercise" }
      ]
    },
    "singleChoiceExercise": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "prompt", "choices", "answer"],
      "properties": {
        "type": { "const": "single_choice" },
        "prompt": { "type": "string", "minLength": 1 },
        "choices": { "$ref": "#/$defs/choices" },
        "answer": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "explanation": { "type": "string" },
        "sort_order": { "type": "integer", "minimum": 0 }
      }
    },
    "multipleChoiceExercise": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "prompt", "choices", "answer"],
      "properties": {
        "type": { "const": "multiple_choice" },
        "prompt": { "type": "string", "minLength": 1 },
        "choices": { "$ref": "#/$defs/choices" },
        "answer": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "explanation": { "type": "string" },
        "sort_order": { "type": "integer", "minimum": 0 }
      }
    },
    "trueFalseExercise": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "prompt", "answer"],
      "properties": {
        "type": { "const": "true_false" },
        "prompt": { "type": "string", "minLength": 1 },
        "answer": { "type": "boolean" },
        "explanation": { "type": "string" },
        "sort_order": { "type": "integer", "minimum": 0 }
      }
    },
    "fillBlankExercise": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "prompt", "answers"],
      "properties": {
        "type": { "const": "fill_blank" },
        "prompt": { "type": "string", "minLength": 1 },
        "answers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/fillBlankAnswer" }
        },
        "explanation": { "type": "string" },
        "sort_order": { "type": "integer", "minimum": 0 }
      }
    },
    "choices": {
      "type": "object",
      "minProperties": 2,
      "propertyNames": {
        "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
      },
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "fillBlankAnswer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["accepted_answer"],
      "properties": {
        "blank_key": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
        },
        "accepted_answer": { "type": "string", "minLength": 1 },
        "match_mode": {
          "enum": ["exact", "trim", "case_insensitive"]
        }
      }
    },
    "programmingProblem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prompt", "language", "entry_file", "starter_code", "tests"],
      "properties": {
        "prompt": { "type": "string", "minLength": 1 },
        "language": { "const": "python" },
        "entry_file": { "type": "string", "minLength": 1 },
        "starter_code": { "type": "string", "minLength": 1 },
        "checker": { "enum": ["exact", "whitespace", "float_tolerance"] },
        "float_tolerance": { "type": "number", "exclusiveMinimum": 0 },
        "time_limit_ms": { "type": "integer", "minimum": 1 },
        "memory_limit_mb": { "type": "integer", "minimum": 1 },
        "explanation": { "type": "string" },
        "sort_order": { "type": "integer", "minimum": 0 },
        "tests": {
          "type": "array",
          "minItems": 2,
          "contains": {
            "type": "object",
            "required": ["visibility"],
            "properties": {
              "visibility": { "const": "sample" }
            }
          },
          "items": {
            "$ref": "#/$defs/programmingTest"
          },
          "allOf": [
            {
              "contains": {
                "type": "object",
                "required": ["visibility"],
                "properties": {
                  "visibility": { "const": "hidden" }
                }
              }
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "checker": { "const": "float_tolerance" }
            },
            "required": ["checker"]
          },
          "then": { "required": ["float_tolerance"] },
          "else": { "not": { "required": ["float_tolerance"] } }
        }
      ]
    },
    "programmingTest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["visibility", "input", "output"],
      "properties": {
        "visibility": { "enum": ["sample", "hidden"] },
        "input": { "type": "string" },
        "output": { "type": "string" },
        "feedback": { "type": "string" },
        "full_feedback": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "visibility": { "const": "hidden" }
            },
            "required": ["visibility"]
          },
          "then": {
            "not": {
              "properties": {
                "full_feedback": { "const": true }
              },
              "required": ["full_feedback"]
            }
          }
        }
      ]
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "type"],
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "type": {
          "enum": [
            "required",
            "recommended",
            "membership",
            "video_pause",
            "peer_review_reference"
          ]
        },
        "at": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            {
              "type": "string",
              "pattern": "^(\\d+|\\d+:\\d{2}|\\d+:\\d{2}:\\d{2})$"
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "video_pause" } },
            "required": ["type"]
          },
          "then": { "required": ["at"] },
          "else": { "not": { "required": ["at"] } }
        }
      ]
    }
  }
}
